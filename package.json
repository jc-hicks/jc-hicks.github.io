{
  "name": "personal-portfolio",
  "version": "1.0.0",
  "description": "A professional front-end-only personal portfolio website built with vanilla HTML5, CSS3, and ES6+ JavaScript modules.",
  "type": "module",
  "main": "js/main.js",
  "scripts": {
    "format": "prettier --write '**/*.{html,css,js,json,md}'",
    "format:check": "prettier --check '**/*.{html,css,js,json,md}'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "serve": "http-server -c-1 -o",
    "dev": "reload -b -d .",
    "validate": "npm run format:check && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jc-hicks/PersonalSite.git"
  },
  "keywords": [
    "portfolio",
    "personal-website",
    "vanilla-javascript",
    "es6-modules",
    "semantic-html"
  ],
  "author": "James Hicks",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jc-hicks/PersonalSite/issues"
  },
  "homepage": "https://github.com/jc-hicks/PersonalSite#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^15.15.0",
    "http-server": "^14.1.1",
    "prettier": "^3.8.3",
    "reload": "^3.2.0"
  },
  "directories": {
    "doc": "docs"
  }
}
